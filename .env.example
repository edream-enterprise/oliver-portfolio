# Decap CMS runtime configuration.
# Set these variables in Dokploy so /admin/config.yml is generated at runtime.

DECAP_BACKEND_NAME=github
DECAP_REPO=edream-enterprise/oliver-portfolio
DECAP_BRANCH=main

# Required in production when using GitHub auth through a self-hosted OAuth proxy.
# Example: https://cms-auth.example.com
DECAP_BASE_URL=

# Optional. Leave empty unless your OAuth proxy uses a non-default auth endpoint.
# Decap defaults to "auth".
DECAP_AUTH_ENDPOINT=

# Local development only. Use with `npx decap-server`.
DECAP_LOCAL_BACKEND=false
